		function injectCSS(file) {
			var link = document.createElement('link');
			link.href = file;
			link.type = 'text/css';
			link.rel = 'stylesheet';
			link.crossOrigin = 'anonymous';

			document.getElementsByTagName('head')[0].appendChild(link);
